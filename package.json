{
  "name": "forminit",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "backend",
    "packages/types"
  ],
  "description": "A modern notion-like form builder.",
  "main": "index.js",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces  --if-present",
    "test:coverage": "npm run test:coverage --workspaces  --if-present",
    "tsc": "npm run tsc --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces --if-present -- --fix",
    "format": "npm run format --workspaces",
    "format:fix": "npm run format:fix --workspaces",
    "prepare": "husky || true",
    "commit": "cz",
    "commit:retry": "cz --retry",
    "commitlint": "commitlint --edit",
    "commitlint:last": "commitlint --from=HEAD~1",
    "pre-commit": "lint-staged"
  },
  "keywords": [],
  "author": "vishnu",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "commitizen": "^4.3.1",
    "commitlint": "^19.8.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.1",
    "prettier": "^3.5.3",
    "typescript": "5.4.5"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "react-smooth": "^4.0.4",
    "recharts": "^3.2.1",
    "recharts-scale": "^0.4.5",
    "tiny-invariant": "^1.3.3"
  }
}
